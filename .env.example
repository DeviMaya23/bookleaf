# Server
PORT=8080

# Database (used by backend/cmd/server/main.go)
DATABASE_HOST=localhost
DATABASE_NAME=bookleaf
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSLMODE=disable
# Optional additional query parameters appended to the DB URL
DATABASE_OPTIONS=connect_timeout=10&application_name=bookleaf

# Kinde Auth
KINDE_ISSUER_URL=https://yourapp.kinde.com
KINDE_AUDIENCE=your-api-audience
KINDE_CLIENT_ID=your-kinde-client-id
KINDE_CLIENT_SECRET=your-kinde-client-secret

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Google Vision
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Observability
OTEL_EXPORTER=tempo
OTEL_METRICS_EXPORTER=prometheus
OTEL_TEMPO_ENDPOINT=localhost:4317
LOG_FORMAT=json
