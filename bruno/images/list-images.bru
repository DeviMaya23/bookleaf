meta {
  name: List Images
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/images
  body: none
  auth: inherit
}

params:query {
  ~cursor: {{imagesCursor}}
  ~folder_id: {{folderId}}
  ~limit: 2
}

script:post-response {
  const cursor = res.body.next_cursor;
  if (cursor) {
    bru.setVar("imagesCursor", cursor);
  } else {
    bru.setVar("imagesCursor", "");
  }
}
