meta {
  name: Initiate Upload
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/images
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "title": "my test photo",
    "mime_type": "image/jpeg"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("imageId", res.body.id);
    bru.setVar("uploadUrl", res.body.upload_url);
  }
}
