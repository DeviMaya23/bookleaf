# Base URL of the Bookleaf backend API (no trailing slash)
VITE_API_BASE_URL=http://localhost:8080

# Kinde application client ID (from Kinde dashboard → Applications)
VITE_KINDE_CLIENT_ID=

# Kinde issuer URL, e.g. https://yourapp.kinde.com
VITE_KINDE_ISSUER_URL=

# OAuth callback URL registered in Kinde (must match exactly)
VITE_KINDE_REDIRECT_URL=http://localhost:5173/callback

# Post-logout redirect URL registered in Kinde
VITE_KINDE_LOGOUT_REDIRECT_URL=http://localhost:5173
